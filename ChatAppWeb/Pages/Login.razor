@page "/Login"
@page "/Login/{successfullRegister:bool}"
@using System.Net
@using Core.DTOs
@using Core
@inject NavigationManager NavigationManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Client
<PageTitle>Login</PageTitle>

@if (loaded)
{
    @if (failed)
    {
        <div class="alert alert-danger alertCenter">
            @errorMessage
        </div>
    }

    @if (successfullRegister)
    {
    <div class="alert alert-success alertCenter" role="alert">
        Successfully registered
    </div>
    }

    <div class="container" style="display: flex; align-items: center; margin-top: 150px;">
        <div class="firstHalf">
            <img alt="company logo" src="Pictures/CompanyLogo.png"/>

            <h1>For you, who want to connect with people</h1>

            <p>ChatAppMe helps you connect to the people you most want to talk to, without hassle, without giving your data to big tech!</p>

            <div class="loginCard">
                <div>
                    <input id="emailORphone" placeholder="Email or Phone number" 
                           @onchange="OnEmailPhoneChange" 
                           @onkeydown="Enter"
                           @onkeyup="Enter">
                    <p style="color: red">@emailOrPhoneError</p>
                </div>

                <div>
                    <input id="password" placeholder="Password" type="password" 
                           @onchange="OnPasswordChange" 
                           @onkeydown="Enter"
                           @onkeyup="Enter">
                    <p style="color: red">@passwordError</p>
                </div>

                <div>
                    <span>Don't have an account? <a href="/register">SIGN IN</a></span>
                </div>

                <div class="loginButtonDiv">
                    <button @onclick="TryLogin" class="btn btn-primary" id="loginButton">Login</button>
                    <span><a href="#">Forgot your password?</a></span>
                </div>
            </div>
        </div>

        <div class="pictureContainer">
            <img alt="Example use of chat app" src="Pictures/LoginPicture.png"/>
        </div>
        
    </div>

    <div class="container">
        <div class="footer">
            <div>
                <span>© MortyG</span>
            </div>
            <div>
                <a href="#">Protection of data (there is none)</a>
            </div>
            <div>
                <a href="#">Cookie policy</a>
            </div>
            <div>
                <a href="#">Terms of use</a>
            </div>
        </div>
    </div>
}


@code {
    private bool loaded = false;
    
    private User? _currentUser;
    private string? _token;
    private string? _refreshToken;
    
    private string emailOrPhone;
    private string emailOrPhoneError;
    
    private string Password;
    private string passwordError;
    
    private bool failed;
    string errorMessage = "";
    
    [Parameter] public bool successfullRegister { get; set; } = false;
    
    protected override async Task OnInitializedAsync()
    {
        _currentUser = await LocalStorage.GetItemAsync<User>("user");
        _token = await LocalStorage.GetItemAsync<string>("token");
        _refreshToken = await LocalStorage.GetItemAsync<string>("refresh");
        
        if(_currentUser != null && _token != null && _refreshToken != null)
            NavigationManager.NavigateTo("/");

        _currentUser = null;
        _token = null;
        _refreshToken = null;

        loaded = true;
        StateHasChanged();
    }
    
    protected override async Task OnParametersSetAsync()
    {
        if (successfullRegister)
            await SuccessfullyRegistered();
    }
    
    private async Task SuccessfullyRegistered()
    {
        StateHasChanged();
        await Task.Delay(3000);
        successfullRegister = false;
        StateHasChanged();
    }

    private void Enter(KeyboardEventArgs e)
    {
        if (e.Code == "Enter" || e.Code == "NumpadEnter")
        {
            TryLogin();
        }
    }

    private void OnPasswordChange(ChangeEventArgs e)
    {
        Password = (string)e.Value;
        passwordError = "";
    }
    
    private void OnEmailPhoneChange(ChangeEventArgs e)
    {
        emailOrPhone = (string)e.Value;
        emailOrPhoneError = "";
    }

    private async Task TryLogin()
    {

        if (string.IsNullOrWhiteSpace(Password) && string.IsNullOrWhiteSpace(emailOrPhone))
        {
            passwordError = "Password is required";
            emailOrPhoneError = "Phone or email is required";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(Password))
        {
            passwordError = "Password is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(emailOrPhone))
        {
            emailOrPhoneError = "Phone or email is required";
            return;
        }
        
        var result = await Client.PostAsJsonAsync("auth/login", new LoginRecord(emailOrPhone, Password));
        if (result.IsSuccessStatusCode)
        {
            var dto = await result.Content.ReadFromJsonAsync<UserTokenDTO>();
            var user = dto!.User;
            var token = dto.Token;
            var refresh = dto.RefreshToken;
            await LocalStorage.SetItemAsync("user", user);
            await LocalStorage.SetItemAsync("token", token);
            await LocalStorage.SetItemAsync("refresh", refresh);
            NavigationManager.NavigateTo("/");
        }

        if (result.StatusCode == HttpStatusCode.BadRequest)
        {
            errorMessage = "Server is down";
            failed = true;
            StateHasChanged();
            await Task.Delay(3000);
            failed = false;
            errorMessage = "";
            StateHasChanged();
        } else if (result.StatusCode == HttpStatusCode.Unauthorized)
        {
            errorMessage = "Incorrect password or username";
            failed = true;
            StateHasChanged();
            await Task.Delay(3000);
            failed = false;
            errorMessage = "";
            StateHasChanged();
        }
        
    }

}